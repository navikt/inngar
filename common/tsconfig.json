{
    "include": ["**/*"],
    "compilerOptions": {
        "lib": ["ES2022"],
        "types": ["node"],
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "skipLibCheck": true,
        "strict": true
    }
}
